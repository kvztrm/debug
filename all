-- RakNet Desync Toggle + Server Position Visualizer
-- Toggle: Q   |   Kill/Reset: X
-- Requires executor with Raknet library (Delta, etc.)

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local Raknet = rawget(_G, "Raknet") or rawget(_G, "raknet")  -- common exposure

local desyncEnabled = false
local visualizerEnabled = true  -- you can toggle this too if wanted
local lastKnownServerCFrame = CFrame.new()  -- fallback if no better way
local serverDummy = nil             -- visual clone
local highlight = nil
local billboard = nil

-- ────────────────────────────────────────────
-- Create visualizer (white outline + red fill)
local function createVisualizer()
    if serverDummy then serverDummy:Destroy() end
    if highlight then highlight:Destroy() end
    if billboard then billboard:Destroy() end

    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return end

    -- Clone a simple dummy for position visualization
    serverDummy = Instance.new("Part")
    serverDummy.Name = "ServerPosDummy"
    serverDummy.Size = char.PrimaryPart.Size + Vector3.new(0.2, 0.2, 0.2)
    serverDummy.Transparency = 0.4
    serverDummy.Color = Color3.fromRGB(255, 0, 0)  -- red fill
    serverDummy.CanCollide = false
    serverDummy.Anchored = true
    serverDummy.Parent = workspace

    highlight = Instance.new("Highlight")
    highlight.Name = "ServerHighlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.35
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = serverDummy
    highlight.Parent = game.CoreGui  -- or serverDummy

    -- Optional billboard label
    billboard = Instance.new("BillboardGui")
    billboard.Name = "ServerLabel"
    billboard.Size = UDim2.new(4, 0, 2, 0)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = serverDummy

    local text = Instance.new("TextLabel", billboard)
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.Text = "SERVER POS"
    text.TextColor3 = Color3.new(1,1,1)
    text.TextStrokeTransparency = 0
    text.TextStrokeColor3 = Color3.new(0,0,0)
    text.Font = Enum.Font.SourceSansBold
    text.TextSize = 24
end

-- Update visualizer position (runs every frame when enabled)
local connection
local function updateVisualizer()
    if connection then connection:Disconnect() end

    connection = RunService.Heartbeat:Connect(function()
        if not visualizerEnabled or not desyncEnabled then return end
        if not serverDummy then return end

        -- Try to use last replicated CFrame (if you have a way to read it)
        -- Fallback: estimate from last movement before desync
        serverDummy.CFrame = lastKnownServerCFrame
    end)
end

-- ────────────────────────────────────────────
-- Desync control (blocks outgoing replication packets)
local sendHookId = nil

local function enableDesync()
    if not Raknet then
        warn("[Desync] No Raknet library found in _G — visualizer only")
        return
    end

    if desyncEnabled then return end
    desyncEnabled = true

    -- Common methods from 2026 executors (Delta/SynZ forks)
    if Raknet.desync then
        Raknet.desync(true)
        print("[Desync] Activated via raknet.desync(true)")
    elseif Raknet.add_send_hook then
        -- Hook outgoing packets and drop replication-related ones
        sendHookId = Raknet.add_send_hook(function(packet)
            -- Very naive filter: drop physics/position replication packets
            -- (real filters are more complex: check opcode, channel, payload)
            if packet:find("Physics") or packet:find("Replicate") or packet:find("CFrame") then
                return false  -- block / don't send
            end
            return true
        end)
        print("[Desync] Activated via send_hook (blocks replication packets)")
    else
        warn("[Desync] No supported Raknet method found")
    end

    -- Record current CFrame as "server pos" baseline
    local char = LocalPlayer.Character
    if char and char.PrimaryPart then
        lastKnownServerCFrame = char.PrimaryPart.CFrame
    end

    createVisualizer()
    updateVisualizer()
end

local function disableDesync()
    if not desyncEnabled then return end
    desyncEnabled = false

    if Raknet then
        if Raknet.desync then
            Raknet.desync(false)
        elseif sendHookId and Raknet.remove_send_hook then
            Raknet.remove_send_hook(sendHookId)
            sendHookId = nil
        end
    end

    if serverDummy then serverDummy:Destroy() serverDummy = nil end
    if highlight then highlight:Destroy() highlight = nil end
    if billboard then billboard:Destroy() billboard = nil end
    if connection then connection:Disconnect() connection = nil end

    print("[Desync] Disabled")
end

-- Kill / full reset (X key)
local function killDesync()
    disableDesync()
    lastKnownServerCFrame = CFrame.new()
    print("[Desync] Killed / reset")
end

-- ────────────────────────────────────────────
-- Toggles
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if input.KeyCode == Enum.KeyCode.Q then
        if desyncEnabled then
            disableDesync()
        else
            enableDesync()
        end
    elseif input.KeyCode == Enum.KeyCode.X then
        killDesync()
    end
end)

-- Auto-update last known server pos (when not desynced)
RunService.Heartbeat:Connect(function()
    if not desyncEnabled then
        local char = LocalPlayer.Character
        if char and char.PrimaryPart then
            lastKnownServerCFrame = char.PrimaryPart.CFrame
        end
    end
end)

print("[RakNet Desync] Loaded")
print("   Q = Toggle desync + visualizer")
print("   X = Kill / reset everything")
print("   Visual: white outline + red fill on estimated server position")
