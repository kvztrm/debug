-- Improved RakNet Desync + Dual Visualizer (Client blue vs Server red/white)
-- Toggle: Q   |   Kill/Reset + Debug: X
-- Watch console for errors / status

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local raknet = rawget(_G, "Raknet") or rawget(_G, "raknet") or rawget(_G, "rnet")  -- try common names

local desyncActive = false
local clientViz, serverViz, clientHighlight, serverHighlight
local lastServerCFrame = CFrame.new()
local lastVelocity = Vector3.new()

-- ────────────────────────────────────────────
local function createVisualizers()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        warn("[Viz] No character / HRP yet - retry after spawn")
        return
    end

    -- Clean old
    if clientViz then clientViz:Destroy() end
    if serverViz then serverViz:Destroy() end
    if clientHighlight then clientHighlight:Destroy() end
    if serverHighlight then serverHighlight:Destroy() end

    -- Client viz (blue - where YOU see yourself)
    clientViz = Instance.new("Part")
    clientViz.Name = "ClientPosViz"
    clientViz.Size = char.HumanoidRootPart.Size + Vector3.new(0.4, 0.4, 0.4)
    clientViz.Transparency = 0.6
    clientViz.Color = Color3.fromRGB(0, 100, 255)  -- blue fill
    clientViz.CanCollide = false
    clientViz.Anchored = true
    clientViz.Parent = workspace

    clientHighlight = Instance.new("Highlight")
    clientHighlight.FillColor = Color3.fromRGB(0, 100, 255)
    clientHighlight.OutlineColor = Color3.fromRGB(200, 200, 255)
    clientHighlight.FillTransparency = 0.5
    clientHighlight.OutlineTransparency = 0
    clientHighlight.Adornee = clientViz
    clientHighlight.Parent = game:GetService("CoreGui")  -- try CoreGui for visibility

    -- Server viz (red fill + white outline)
    serverViz = Instance.new("Part")
    serverViz.Name = "ServerPosViz"
    serverViz.Size = clientViz.Size
    serverViz.Transparency = 0.4
    serverViz.Color = Color3.fromRGB(255, 0, 0)  -- red fill
    serverViz.CanCollide = false
    serverViz.Anchored = true
    serverViz.Parent = workspace

    serverHighlight = Instance.new("Highlight")
    serverHighlight.FillColor = Color3.fromRGB(255, 0, 0)
    serverHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    serverHighlight.FillTransparency = 0.35
    serverHighlight.OutlineTransparency = 0
    serverHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    serverHighlight.Adornee = serverViz
    serverHighlight.Parent = game:GetService("CoreGui")

    print("[Viz] Visualizers created - blue = your local pos, red/white = server pos")
end

-- Update loop
local updateConn
local function startUpdateLoop()
    if updateConn then updateConn:Disconnect() end
    updateConn = RunService.Heartbeat:Connect(function(dt)
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end

        local hrp = char.HumanoidRootPart

        -- Client viz always follows real local position
        if clientViz then
            clientViz.CFrame = hrp.CFrame
        end

        -- Server viz: fallback prediction (last known + velocity * estimated lag)
        -- Not perfect, but better than nothing without packet reading
        if serverViz and desyncActive then
            lastVelocity = hrp.AssemblyLinearVelocity
            lastServerCFrame = lastServerCFrame + lastVelocity * dt  -- crude extrapolation
            serverViz.CFrame = lastServerCFrame
        end
    end)
end

-- ────────────────────────────────────────────
local hookId = nil

local function toggleDesync()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        warn("[Desync] No character loaded - wait and try again")
        return
    end

    desyncActive = not desyncActive

    if desyncActive then
        lastServerCFrame = char.HumanoidRootPart.CFrame  -- baseline
        createVisualizers()
        startUpdateLoop()

        if not raknet then
            warn("[Desync] No Raknet/rnet found in _G - visualizer only (no real desync)")
        else
            -- Try common 2026 APIs
            if raknet.desync then
                raknet.desync(true)
                print("[Desync] Activated via raknet.desync(true)")
            elseif raknet.enable then
                raknet.enable()  -- some use this
                print("[Desync] Activated via raknet.enable()")
            elseif raknet.startcapture then  -- Celery style
                raknet.startcapture()
                print("[Desync] Capture started (may need manual packet drop)")
            else
                warn("[Desync] Unknown Raknet API - check executor docs or print(raknet)")
            end
        end
    else
        if raknet then
            if raknet.desync then raknet.desync(false) end
            if raknet.disable then raknet.disable() end
            if raknet.stopcapture then raknet.stopcapture() end
        end
        if updateConn then updateConn:Disconnect() end
        print("[Desync] Disabled")
    end
end

local function killEverything()
    desyncActive = false
    if updateConn then updateConn:Disconnect() end
    if clientViz then clientViz:Destroy() end
    if serverViz then serverViz:Destroy() end
    if clientHighlight then clientHighlight:Destroy() end
    if serverHighlight then serverHighlight:Destroy() end
    lastServerCFrame = CFrame.new()
    lastVelocity = Vector3.new()
    print("[Kill] Everything reset. Check console for Raknet status:")
    if raknet then
        for k,v in pairs(raknet) do
            print("   raknet." .. tostring(k) .. " = " .. tostring(v))
        end
    else
        print("   No raknet table found")
    end
end

-- ────────────────────────────────────────────
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.Q then
        toggleDesync()
    elseif input.KeyCode == Enum.KeyCode.X then
        killEverything()
    end
end)

-- Auto-baseline when not desynced
RunService.Heartbeat:Connect(function()
    if not desyncActive then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            lastServerCFrame = hrp.CFrame
        end
    end
end)

print("[Desync Visualizer v2] Loaded")
print("Q = Toggle desync + show visualizers")
print("X = Kill everything + dump Raknet debug info")
print("Blue transparent = your local/client position")
print("Red fill + white outline = estimated server position")
print("If nothing shows: check character loaded? Executor console for warnings?")
